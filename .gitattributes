# Default: normalise line endings to LF in the repository
* text=auto

# PowerShell scripts must have CRLF line endings so that
# Windows PowerShell 5.1 can parse here-strings correctly.
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf

# Shell scripts always use LF
*.sh    text eol=lf
